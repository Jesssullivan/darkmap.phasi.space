{
	"$schema": "../docs/schemas/lanes.schema.json",
	"schema_version": 1,
	"spoke": {
		"name": "darkmap",
		"domain": "darkmap.phasi.space"
	},
	"defaults": {
		"runner_class": "tinyland-nix",
		"ttl_hours": 72,
		"flywheel_target_classes": ["sveltekit-unit-tests", "sveltekit-app-build"]
	},
	"lanes": [
		{
			"name": "default",
			"trigger": "pull_request",
			"theme": "darkmap",
			"snapshot_source": "checked-in",
			"e2e": false
		}
	]
}
