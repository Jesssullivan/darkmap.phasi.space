# darkmap.tinyland.dev Bazel Configuration
#
# Bazel 8 + Bzlmod. Mirrors elders.tinyland.dev's two-registry chain:
# tinyland-inc/bazel-registry first, then BCR. Site build remains
# `pnpm run build`; Bazel exists for module-graph integrity proofs.

common --enable_bzlmod
common --registry=https://raw.githubusercontent.com/tinyland-inc/bazel-registry/main/
common --registry=https://bcr.bazel.build

# Build performance
build --jobs=auto
build --worker_sandboxing
build --disk_cache=~/.cache/bazel-darkmap
build --keep_going
build --show_timestamps

# Cache-attachment contract (mirrors MassageIthaca/scripts/cache-attachment-contract.sh).
#
# We do NOT hardcode a remote-cache endpoint here — endpoints are
# operator-attached via BAZEL_REMOTE_CACHE / BAZEL_REMOTE_EXECUTOR env
# vars, validated by scripts/cache-attachment-contract.sh, and passed
# on the command line by scripts/bazel-cache-backed.sh.
#
#   compatibility-local-only:  no env vars → bazel runs in local sandbox
#   shared-cache-backed:       BAZEL_REMOTE_CACHE only
#   executor-backed:           BAZEL_REMOTE_CACHE + BAZEL_REMOTE_EXECUTOR
common:ci-cached --remote_cache_async
common:ci-cached --remote_upload_local_results=true
common:ci-cached --remote_local_fallback
common:ci-cached --remote_timeout=120
common:ci-cached --remote_retries=3
common:ci-cached --experimental_remote_cache_compression

common:executor-backed --remote_cache_async
common:executor-backed --remote_upload_local_results=true
common:executor-backed --remote_local_fallback
common:executor-backed --remote_timeout=300
common:executor-backed --remote_retries=3
common:executor-backed --experimental_remote_cache_compression

# Local override knob — `--config=no-remote-cache` blanks the
# wrapper-supplied endpoint for debugging.
build:no-remote-cache --remote_cache=

# rules_ts: skip lib check is required for SvelteKit-style declaration files.
build --@aspect_rules_ts//ts:skipLibCheck=always
build --spawn_strategy=sandboxed,worker,local

# CI: hosted runners, no remote cache.
build:ci --remote_retries=3
build:ci --jobs=auto
build:ci --color=no
build:ci --curses=no
build:ci --show_progress_rate_limit=30
build:ci --noshow_loading_progress

# Test output
test --test_output=errors
test --test_summary=detailed
test --test_verbose_timeout_warnings
test --test_timeout=120,600,1800,3600

try-import %workspace%/user.bazelrc
