"""
Root BUILD.bazel for darkmap.phasi.space.

Minimal: just create the @npm//... node_modules tree. The SvelteKit
static site is built by `pnpm run build` (vite build) — Bazel does not
produce build/.
"""

load("@aspect_rules_js//js:defs.bzl", "js_binary", "js_library", "js_run_binary", "js_test")
load("@npm//:defs.bzl", "npm_link_all_packages")
load("@npm//:vitest/package_json.bzl", vitest = "bin")

npm_link_all_packages(name = "node_modules")

js_library(
    name = "package_json",
    srcs = ["package.json"],
    visibility = ["//visibility:public"],
)

js_library(
    name = "vitest_config",
    srcs = ["vitest.config.ts"],
    visibility = ["//visibility:public"],
)

js_library(
    name = "vitest_bazel_config",
    srcs = ["vitest.bazel.config.ts"],
    visibility = ["//visibility:public"],
)

exports_files(
    [
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "vitest.bazel.config.ts",
        "vitest.config.ts",
    ],
    visibility = ["//visibility:public"],
)
# Cross-slice `$lib/...` sources pulled into flywheel-enrolled unit-test
# slices (atmospheric/cache/sw). These files live in the root Bazel package
# (no nearer BUILD.bazel). aspect_rules_js requires cross-package inputs to be
# copied to the bin tree via a js_library (raw file labels are rejected), so
# each is wrapped here and consumed from the slice filegroups.
js_library(
    name = "lib_layers",
    srcs = ["src/lib/layers.ts"],
    visibility = ["//visibility:public"],
)

# Basemap catalogue consumed by the layers slice (`toast-bridge.ts` imports
# `$lib/basemaps`'s BASEMAPS as a VALUE). Self-contained root-package module.
js_library(
    name = "lib_basemaps",
    srcs = ["src/lib/basemaps.ts"],
    visibility = ["//visibility:public"],
)

# SGP4 orbit helpers consumed by the map slice (`orbit-footprint.ts` imports
# `$lib/orbit`'s subSatellitePoint / footprintRadiusKm / geodesicRing as VALUES).
# Self-contained root-package module (its only `$lib` import is type-only).
js_library(
    name = "lib_orbit",
    srcs = ["src/lib/orbit.ts"],
    visibility = ["//visibility:public"],
)

# Note: the former //:lib_cache_policy / //:lib_offline_cache_service /
# //:lib_offline_cache_routes wrappers moved into
# //src/lib/effect/services:{cache_policy,offline_cache_service,offline_cache_routes}
# once that directory gained its own BUILD.bazel (a subpackage's files can no
# longer be referenced from the root package).

# Atmospheric capability table consumed by the effect/services slice
# (AtmosphericTileService imports `$lib/atmospheric-capabilities`). Lives in the
# root Bazel package (no nearer BUILD.bazel); its sole intra-root import of
# `./layers` is `import type` (erased), so the bin-copy needs no companion.
js_library(
    name = "lib_atmospheric_capabilities",
    srcs = ["src/lib/atmospheric-capabilities.ts"],
    visibility = ["//visibility:public"],
)

# Curated HITRAN line archive consumed by the spectral slice's
# hitran-bands.test.ts. The test resolves it via
# `resolve(process.cwd(), 'data', 'hitran', 'curated-lines.json')`; the vitest
# runner's cwd is the runfiles root, and js_library stages the file at its
# root-package path (`data/hitran/...`), so the same `process.cwd()` lookup
# resolves identically under `pnpm test` and `bazel test`. Lives in the root
# Bazel package (no nearer BUILD.bazel), so wrapped here like the cross-slice
# `$lib/...` sources above.
js_library(
    name = "hitran_curated_lines",
    srcs = ["data/hitran/curated-lines.json"],
    visibility = ["//visibility:public"],
)

# =============================================================================
# sveltekit-app-build — RBE-enrolled adapter-node build target
#
# Wraps the canonical `pnpm run build` (vite build + SvelteKit adapter-node)
# as a hermetic Bazel action so it earns remote-cache + RBE acceleration under
# the proved `sveltekit-app-build` target class. Modeled on tinyland.dev's
# //:app_node_build (the proved TS-RBE reference).
#
# The runner stages all srcs into an isolated temp workspace, runs
# `svelte-kit sync` + `vite build`, and copies the adapter-node bundle back to
# the exec-root `build/` directory, which rules_js captures via out_dirs.
#
# tags:
#   - flywheel-eligible : gates dispatch under --config=flywheel-executor
#                         (--build_tag_filters=flywheel-eligible).
#   - manual            : excluded from bare `bazelisk build //...` so the
#                         8-min app build never runs on incidental wildcards.
# =============================================================================

js_binary(
    name = "app_build_tool",
    entry_point = "scripts/bazel/run-vite-node-build.mjs",
    visibility = ["//visibility:public"],
)

js_run_binary(
    name = "app_build",
    srcs = glob(
        [
            "src/**/*",
            "static/**/*",
            "data/**/*",
        ],
        allow_empty = True,
    ) + [
        # Bazel globs stop at sub-package boundaries, so the root `src/**/*`
        # glob omits the two nested packages under src/lib. The SvelteKit SSR
        # build imports their modules (e.g. `$lib/server/raster/RasterClient`),
        # so pull their source filegroups in explicitly or the build fails with
        # UNLOADABLE_DEPENDENCY / "No such file or directory".
        "//src/lib/server/raster:raster_app_srcs",
        "//src/lib/ephemeris:ephemeris_app_srcs",
        # Newly-created unit-test packages also become sub-package boundaries the
        # root `src/**/*` glob stops at; the SSR build imports their modules, so
        # pull each one's non-test sources in explicitly. The real executor proof
        # relies on this complete source tree because Vite runs inside a remote
        # action sandbox instead of the developer checkout.
        "//src/lib/actions:actions_app_srcs",
        "//src/lib/atmospheric:atmospheric_app_srcs",
        "//src/lib/cache:cache_app_srcs",
        "//src/lib/device:device_app_srcs",
        "//src/lib/effect/services:services_app_srcs",
        "//src/lib/geocoder:geocoder_app_srcs",
        "//src/lib/layers:layers_app_srcs",
        "//src/lib/map:map_app_srcs",
        "//src/lib/projection:projection_app_srcs",
        "//src/lib/routes:routes_app_srcs",
        "//src/lib/server/geocoder:geocoder_app_srcs",
        "//src/lib/spectral:spectral_app_srcs",
        "//src/lib/sw:sw_app_srcs",
        "//src/lib/transmission:transmission_app_srcs",
        "package.json",
        "pnpm-lock.yaml",
        "pnpm-workspace.yaml",
        "tsconfig.json",
        "svelte.config.js",
        "vite.config.ts",
        ":node_modules",
    ],
    out_dirs = ["build"],
    tool = ":app_build_tool",
    tags = [
        "flywheel-eligible",
        "manual",
    ],
    visibility = ["//visibility:public"],
)

