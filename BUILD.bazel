# =============================================================================
# playwright_browser_rbe_smoke_suite — one GF-dispatchable browser proof surface
#
# The individual Playwright/Chromium targets above stay split so proof failures
# point at the smallest UI contract. This suite is the operator-facing entry
# point for GloriousFlywheel proof dispatch: it keeps all browserful work manual,
# tagged as RBE-candidate, and out of wildcard/local `bazel test //...` runs.
#
# test_suite.tags are filters, not just metadata. Keep this list to tags shared
# by every member target; adding a suite-only tag filters the suite to zero tests.
# =============================================================================
test_suite(
    name = "playwright_browser_rbe_smoke_suite",
    tags = [
        "chromium",
        "flywheel-eligible",
        "gloriousflywheel-rbe-candidate",
        "local-server-route-smoke",
        "manual",
        "playwright",
    ],
    tests = [
        ":playwright_local_route_smoke",
        ":playwright_mobile_layers_smoke",
        ":playwright_map_canvas_smoke",
        ":playwright_point_readout_smoke",
        ":playwright_mobile_hud_smoke",
        ":playwright_mobile_hud_matrix_smoke",
        ":playwright_lens_smoke",
        ":playwright_toolbar_labels_smoke",
        ":playwright_lens_reweight_smoke",
        ":playwright_link_budget_smoke",
        ":playwright_click_budget_smoke",
        ":playwright_orbit_smoke",
        ":playwright_smog_smoke",
        ":playwright_aq_dashboard_smoke",
    ],
    visibility = ["//visibility:public"],
)

# =============================================================================
# webkit_smoke_suite — the WebKit-engine twin of the chromium proof (RBE-native
# WebKit wiring). iOS Safari AND iOS Chrome are both WebKit, and the dock/mobile
# bugs reproduced ONLY there — the chromium cell is structurally blind to them.
# Same scenario harness, engine-selected via DARKMAP_RBE_SMOKE_ENGINE=webkit.
#
# NOT in playwright_browser_rbe_smoke_suite and NOT flywheel-tagged yet: the GF
# executor image is chromium-only (fontless/swiftshader). A WebKit cell needs
# `playwright install-deps webkit` + REAL FONTS (no fontless mode) — that image
# is the cross-repo (GloriousFlywheel) workstream. Until it exists these run
# LOCALLY: `bazelisk test //:webkit_smoke_suite` (or `just webkit-smoke`),
# resolving Playwright's managed webkit binary (pnpm exec playwright install webkit).
# =============================================================================
js_test(
    name = "playwright_webkit_shell_smoke",
    data = [
        ":app_build",
        ":node_modules",
        "scripts/bazel/run-playwright-local-route-smoke.mjs",
        "scripts/bazel/run-playwright-webkit-shell-smoke.mjs",
    ],
    entry_point = "scripts/bazel/run-playwright-webkit-shell-smoke.mjs",
    tags = [
        "local-server-route-smoke",
        "manual",
        "playwright",
        "webkit",
        "webkit-rbe-candidate",
    ],
    timeout = "moderate",
    visibility = ["//visibility:public"],
)

