# =============================================================================
# root_lib_test — top-level src/lib unit-test slice
#
# The `src/lib` top-level modules (basemaps, layers, lens, url-hash,
# viewportGrid, atmospheric-capabilities) live in the ROOT Bazel package (no
# nearer BUILD.bazel), so their *.test.ts slices are enrolled here rather than
# via a nested package. Every dep is an intra-root same-package file, referenced
# by plain label; all are self-contained (no cross-package `$lib`, no DOM/
# maplibre at module load). atmospheric-capabilities.ts's only intra-root import
# (`./layers`) is `import type` (erased); url-hash.ts imports `./lens` (pure
# type + guards — the rune store `lens.svelte.ts` is NOT in this slice).
# =============================================================================
vitest.vitest_test(
    name = "root_lib_test",
    data = [
        "src/lib/atmospheric-capabilities.test.ts",
        "src/lib/atmospheric-capabilities.ts",
        "src/lib/basemaps.ts",
        "src/lib/layers.invariants.test.ts",
        "src/lib/layers.test.ts",
        "src/lib/layers.ts",
        "src/lib/lens.test.ts",
        "src/lib/lens.ts",
        "src/lib/linkBudget.test.ts",
        "src/lib/linkBudget.ts",
        "src/lib/orbit.test.ts",
        "src/lib/orbit.ts",
        "src/lib/readoutRelevance.test.ts",
        "src/lib/readoutRelevance.ts",
        "src/lib/skyBrightness.test.ts",
        "src/lib/skyBrightness.ts",
        "src/lib/url-hash.test.ts",
        "src/lib/url-hash.ts",
        "src/lib/viewportGrid.test.ts",
        "src/lib/viewportGrid.ts",
        ":node_modules",
        ":package_json",
        ":vitest_bazel_config",
    ],
    args = [
        "run",
        "--reporter=verbose",
        "--config",
        "vitest.bazel.config.ts",
        "src/lib/atmospheric-capabilities.test.ts",
        "src/lib/layers.invariants.test.ts",
        "src/lib/layers.test.ts",
        "src/lib/lens.test.ts",
        "src/lib/linkBudget.test.ts",
        "src/lib/orbit.test.ts",
        "src/lib/readoutRelevance.test.ts",
        "src/lib/skyBrightness.test.ts",
        "src/lib/url-hash.test.ts",
        "src/lib/viewportGrid.test.ts",
    ],
    log_level = "info",
    tags = [
        # flywheel-eligible: --config=flywheel-executor's tag filter dispatches
        # only targets carrying this tag; without it the executor config matched
        # zero targets (a silent no-op). Cache mode (--config=flywheel) ignores
        # tag filters, so this does not change the current cache-backed CI.
        "flywheel-eligible",
        "gloriousflywheel-cache-candidate",
        "vitest",
    ],
    visibility = ["//visibility:public"],
)
