{
	"$schema": "./docs/schemas/tinyland-repo-manifest.schema.json",
	"schema_version": 1,
	"repo": {
		"name": "darkmap.phasi.space",
		"github": "Jesssullivan/darkmap.phasi.space",
		"domain": "darkmap.phasi.space",
		"description": "Public dark-sky planning map for astronomy, field sensing, cycling, hiking, and low-light logistics.",
		"linear": {
			"issue": "TIN-1534"
		}
	},
	"taxonomy": {
		"primary_role": "static-spoke",
		"layers": ["org-wide-repo-contract", "bazel-package-cache-rbe", "static-spoke"]
	},
	"contracts": {
		"agent_contract": "AGENTS.md",
		"just": "Justfile",
		"nix": "flake.nix",
		"github_actions": ".github/workflows",
